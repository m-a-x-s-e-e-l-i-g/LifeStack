# ---------------------------------------------------------------------------
# LifeStack environment. Copy to `.env` and adjust. `docker compose up` reads it.
# ---------------------------------------------------------------------------

# ClickHouse (analytics database)
CLICKHOUSE_DB=lifestack
CLICKHOUSE_USER=lifestack
CLICKHOUSE_PASSWORD=lifestack
CLICKHOUSE_HTTP_PORT=8123

# Backend (aggregator API)
BACKEND_PORT=4000
# Internal URL the backend uses to reach ClickHouse (docker network).
CLICKHOUSE_URL=http://clickhouse:8123
LOG_LEVEL=info

# ---------------------------------------------------------------------------
# AI assistant (chat-first). Provider-agnostic, OpenAI-compatible API.
# Self-hosted example (Ollama):  AI_BASE_URL=http://host.docker.internal:11434/v1
#                                AI_MODEL=llama3.1
# OpenAI example:                AI_BASE_URL=https://api.openai.com/v1
#                                AI_MODEL=gpt-4o-mini   AI_API_KEY=sk-...
# Leave blank to configure later in Settings.
# ---------------------------------------------------------------------------
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=

# Frontend (SvelteKit)
FRONTEND_PORT=3000
# Internal URL the frontend server uses to reach the backend (docker network).
BACKEND_URL=http://backend:4000
# Public origin of the frontend, used for CSRF on form actions.
ORIGIN=http://localhost:3000

# ---------------------------------------------------------------------------
# Connector credentials (optional). Can also be set per connector in Settings.
# Nothing is seeded: modules stay empty until you connect a source or import.
# ---------------------------------------------------------------------------

# Trakt (Movies & TV): create an app at https://trakt.tv/oauth/applications
TRAKT_CLIENT_ID=
TRAKT_ACCESS_TOKEN=

# Tibber (Energy): personal token from https://developer.tibber.com
TIBBER_TOKEN=

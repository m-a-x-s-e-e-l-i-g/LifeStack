# ---------------------------------------------------------------------------
# LifeStack environment. Copy to `.env` and adjust. `docker compose up` reads it.
# ---------------------------------------------------------------------------

# Postgres
POSTGRES_USER=lifestack
POSTGRES_PASSWORD=lifestack
POSTGRES_DB=lifestack
POSTGRES_PORT=5432

# Backend (aggregator API)
BACKEND_PORT=4000
DATABASE_URL=postgres://lifestack:lifestack@postgres:5432/lifestack
LOG_LEVEL=info

# Populate demo data on first boot so the dashboard looks alive immediately.
# Set to false for a clean, empty install.
SEED_DEMO=true

# Frontend (SvelteKit)
FRONTEND_PORT=3000
# Internal URL the frontend server uses to reach the backend (docker network).
BACKEND_URL=http://backend:4000
# Public origin of the frontend, used for CSRF on form actions.
ORIGIN=http://localhost:3000

# ---------------------------------------------------------------------------
# Module secrets (optional). Modules read these via their config.
# Leave blank to run modules in demo mode.
# ---------------------------------------------------------------------------

# Trakt (Movies module): create an app at https://trakt.tv/oauth/applications
TRAKT_CLIENT_ID=
TRAKT_ACCESS_TOKEN=

# Tibber (Energy module): personal token from https://developer.tibber.com
TIBBER_TOKEN=
